# Database Configuration
DB_HOST=localhost
DB_USER=foodshare_user
DB_PASSWORD=your_secure_password_here
DB_NAME=foodshare
DB_PORT=3306

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_minimum_32_characters_long

# Server Configuration
PORT=3001
NODE_ENV=development

# Super Admin Configuration
SUPER_ADMIN_EMAIL=admin@foodshare.com
SUPER_ADMIN_PASSWORD=your_secure_admin_password
SUPER_ADMIN_NAME=Super Administrador
SUPER_ADMIN_RESET_PASSWORD=0

# CORS Configuration (for production)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Email Configuration (optional, for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@foodshare.com
